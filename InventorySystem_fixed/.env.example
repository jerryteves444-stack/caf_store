# Copy this file to .env and fill in real values before running the app.

# --- Core ---
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# DB_ENGINE=sqlite   -> uses SQLite (db.sqlite3), good for local dev
# DB_ENGINE=postgres -> uses PostgreSQL, required for production
DB_ENGINE=sqlite
DB_NAME=store_system
DB_USER=store_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# On Vercel, set DATABASE_URL instead (a single Postgres connection string,
# e.g. from Neon/Supabase/Vercel Postgres) - it takes priority over the
# DB_* vars above when present. Example:
# DATABASE_URL=postgres://user:password@host/dbname

# --- Production-only (set these in the Vercel dashboard, not here) ---
# ALLOWED_HOSTS=yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# (Vercel's own *.vercel.app deployment domain is trusted automatically.)

# --- Session / security ---
SESSION_COOKIE_AGE=28800
SECURE_SSL_REDIRECT=True
TIME_ZONE=Asia/Manila

# --- Business rules ---
LOW_STOCK_DEFAULT_THRESHOLD=10
EXPIRY_WARNING_DAYS=7
DEFAULT_TAX_RATE=0.12
CURRENCY_SYMBOL=₱
